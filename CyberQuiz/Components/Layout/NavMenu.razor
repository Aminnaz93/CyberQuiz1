@implements IDisposable
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CyberQuiz</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (AuthService.IsLoggedIn)
        {
            // Inloggad — visa kategorier, profil och logga ut
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="categories">
                    <span class="bi bi-shield-fill-nav-menu" aria-hidden="true"></span> Kategorier
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profile">
                    <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Profil
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <button class="nav-link" @onclick="Logout">
                    <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logga ut
                </button>
            </div>
        }
        else
        {
            // Utloggad — visa logga in och registrera
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Logga in
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Registrera
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private void Logout()
    {
        // Rensa token och userId från minnet
        AuthService.Logout();

        // Navigera till startsidan
        NavigationManager.NavigateTo("/");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
