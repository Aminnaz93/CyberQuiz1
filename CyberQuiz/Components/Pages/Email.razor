@page "/Email"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using CyberQuiz.Shared.DTOs

<PageTitle>Ändra e-post</PageTitle>

<div class="row">
    <div class="col-md-4">

        <h2>Ändra e-post</h2>

        @if (errorMessage != null)
        {
            <p class="text-danger">@errorMessage</p>
        }

        @if (successMessage != null)
        {
            <p class="text-success">@successMessage</p>
        }

        <div class="form-floating mb-3">
            <input type="email" class="form-control" placeholder="Ny e-postadress"
                   @bind="newEmail" />
            <label>Ny e-post</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="Nuvarande lösenord"
                   @bind="currentPassword" />
            <label>Nuvarande lösenord</label>
        </div>

        <button class="w-100 btn btn-lg btn-primary" @onclick="ChangeEmail">Spara</button>

        <hr />
        <p><a href="/profile">← Tillbaka till profil</a></p>

    </div>
</div>

@code {
    private string newEmail = "";
    private string currentPassword = "";
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        // Om användaren inte är inloggad — gå till login
        if (!AuthService.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task ChangeEmail()
    {
        errorMessage = null;
        successMessage = null;

        var dto = new ChangeEmailDto
        {
            NewEmail = newEmail,
            CurrentPassword = currentPassword
        };

        // Skickar till API
        var response = await Http.PutAsJsonAsync("api/auth/email", dto);

        if (response.IsSuccessStatusCode)
        {
            successMessage = "E-post har bytts!";
            newEmail = "";
            currentPassword = "";
        }
        else
        {
            errorMessage = "Något gick fel. Kontrollera att lösenordet är rätt.";
        }
    }
}
