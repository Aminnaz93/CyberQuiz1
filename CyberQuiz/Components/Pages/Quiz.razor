@page "/quiz/{SubCategoryId:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using CyberQuiz.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Quiz</PageTitle>

<div class="quiz-container">

    @if (questions == null)
    {
        <p>Laddar frågor...</p>
    }
    else if (!questions.Any())
    {
        <p>Inga frågor hittades.</p>
    }
    else
    {
        <h2>Frågor</h2>

        @foreach (var question in questions)
        {
            <div class="question-card">
                <p class="question-text">@question.Text</p>

                @foreach (var option in question.AnswerOptions)
                {
                    var cssClass = GetAnswerClass(question.Id, option.Id);

                    <button class="answer-btn @cssClass"
                            @onclick="() => SubmitAnswer(question.Id, option.Id)"
                            disabled="@HasAnswered(question.Id)">
                        @option.Text
                    </button>
                }

                @if (results.ContainsKey(question.Id))
                {
                    var result = results[question.Id];
                    @if (result.IsCorrect)
                    {
                        <p class="feedback correct">Rätt svar!</p>
                    }
                    else
                    {
                        <p class="feedback incorrect">Fel svar!</p>
                    }
                }
            </div>
        }

        @if (results.Count == questions.Count)
        {
            <div class="result-summary">
                <p>Du fick @results.Values.Count(r => r.IsCorrect) av @questions.Count rätt!</p>
                <button class="back-btn" @onclick="GoBack">← Tillbaka till subkategorier</button>
            </div>
        }
    }
</div>

<style>
    .quiz-container {
        max-width: 600px;
        margin: 2rem auto;
        padding: 1rem;
    }

        .quiz-container h2 {
            margin-bottom: 1.5rem;
        }

    .question-card {
        border: 2px dashed #ccc;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        background: white;
    }

    .question-text {
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .answer-btn {
        display: block;
        width: 100%;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        border: 2px solid #ccc;
        border-radius: 6px;
        background: white;
        cursor: pointer;
        text-align: left;
        font-size: 0.95rem;
        transition: background 0.2s;
    }

        .answer-btn:hover:not(:disabled) {
            border-color: #7c3aed;
            background: #f3f0ff;
        }

        .answer-btn:disabled {
            cursor: not-allowed;
        }

        .answer-btn.correct {
            border-color: #16a34a;
            background: #dcfce7;
        }

        .answer-btn.incorrect {
            border-color: #dc2626;
            background: #fee2e2;
        }

    .feedback {
        margin-top: 0.75rem;
        font-weight: 600;
    }

        .feedback.correct {
            color: #16a34a;
        }

        .feedback.incorrect {
            color: #dc2626;
        }

    .result-summary {
        text-align: center;
        padding: 1.5rem;
        border: 2px solid #7c3aed;
        border-radius: 8px;
        background: #f3f0ff;
    }

        .result-summary p {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

    .back-btn {
        padding: 0.75rem 1.5rem;
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1rem;
    }

        .back-btn:hover {
            background: #6d28d9;
        }
</style>

@code {
    [Parameter]
    public int SubCategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "categoryId")]
    public int? CategoryId { get; set; }

    private List<QuestionDto>? questions = null;
    private Dictionary<int, AnswerResultDto> results = new();

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    // Sparar userId så vi kan använda den i SubmitAnswer också
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        userId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (userId == null) return;

        questions = await Http.GetFromJsonAsync<List<QuestionDto>>($"api/quiz/{SubCategoryId}");

        if (questions != null)
        {
            //blanda svarsalternativen så inte rätt är första valet varje gång och uppdatera listan
            var random = new Random();
            foreach (var question in questions)
            {
                var shuffled = question.AnswerOptions.OrderBy(x => random.Next()).ToList();
                question.AnswerOptions.Clear();
                question.AnswerOptions.AddRange(shuffled);
            }
        }
    }

    private async Task SubmitAnswer(int questionId, int selectedOptionId)
    {
        var result = await Http.PostAsJsonAsync("api/quiz/answer", new AnswerSubmitDto
        {
            QuestionId = questionId,
            SelectedAnswerOptionId = selectedOptionId,
            // skickar userId nu
            UserId = userId ?? ""  
        });

        if (result.IsSuccessStatusCode)
        {
            var answerResult = await result.Content.ReadFromJsonAsync<AnswerResultDto>();
            if (answerResult != null)
                results[questionId] = answerResult;
        }
    }

    private string GetAnswerClass(int questionId, int optionId)
    {
        if (!results.ContainsKey(questionId))
            return "";

        var result = results[questionId];

        if (optionId == result.CorrectAnswerOptionId)
            return "correct";

        if (optionId != result.CorrectAnswerOptionId && results[questionId].IsCorrect == false)
            return "incorrect";

        return "";
    }

    private bool HasAnswered(int questionId)
    {
        return results.ContainsKey(questionId);
    }

    private void GoBack()
    {
        //Koll att kategorin finns om inte skickas man till Category-sidan
        if (CategoryId.HasValue)
        {
            NavigationManager.NavigateTo($"/subcategories/{CategoryId.Value}");
        }
        else
        {
            NavigationManager.NavigateTo("/categories");
        }
    }
}