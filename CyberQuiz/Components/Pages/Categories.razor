@page "/categories"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using CyberQuiz.Shared.DTOs

<PageTitle>Kategorier</PageTitle>

<div class="categories-container">
    <h2>Välj en kategori</h2>

    @if (categories == null)
    {
        <p>Laddar kategorier...</p>
    }
    else
    {
        @foreach (var category in categories)
        {
            <div class="category-card"
                 @onclick="() => OnCategoryClick(category)">
                <h3>@category.Name</h3>
                <p>@category.SubCategories.Count subkategorier</p>
            </div>
        }
    }
</div>

@* samma style som innan *@

@code {
    private List<CategoryDto>? categories = null;

    protected override async Task OnInitializedAsync()
    {
        // Omdirigera till login om användaren inte är inloggad
        if (!AuthService.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        // Skickar userId till API (HttpClient har redan Bearer-token satt av AuthService)
        categories = await Http.GetFromJsonAsync<List<CategoryDto>>(
            $"api/categories?userId={AuthService.UserId}");
    }

    private void OnCategoryClick(CategoryDto category)
    {
        NavigationManager.NavigateTo($"/subcategories/{category.Id}");
    }
}