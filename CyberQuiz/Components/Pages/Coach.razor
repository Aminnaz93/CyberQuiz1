@page "/coach"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using CyberQuiz.Shared.DTOs

<PageTitle>AI Coach</PageTitle>

<div class="coach-container">
    <div class="coach-card">

        <div class="shield">🤖</div>
        <h1>AI Coach</h1>
        @if (SubCategoryId.HasValue)
        {
            @if (!string.IsNullOrEmpty(SubCategoryName))
            {
                <p>Personlig analys av dina quiz-resultat inom @SubCategoryName</p>
            }
            else if (recommendations?.AnalyzedCategories?.Count == 1)
            {
                <p>Personlig analys av ditt quiz-resultat inom @recommendations.AnalyzedCategories.First()</p>
            }
            else
            {
                <p>Personlig analys av ditt quiz-resultat</p>
            }
        }
        else
        {
            <p>Personlig analys av alla dina quiz-resultat</p>
        }

        <!-- ═══ ZON 1: STATS ═══ -->
        @if (recommendations != null)
        {
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-label">Besvarade frågor</div>
                    <div class="stat-value">@recommendations.TotalQuestionsAnswered</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Rätt svar</div>
                    <div class="stat-value green">@recommendations.SuccessRate.ToString("F0")%</div>
                </div>
                @if (!SubCategoryId.HasValue)
                {
                    <div class="stat-card">
                        <div class="stat-label">Svagaste område</div>
                        <div class="stat-value orange">@(recommendations.WeakestCategory ?? "–")</div>
                    </div>
                }
            </div>
        }

        <!-- ═══ ZON 2: STUDIERÅD ═══ -->
        <div class="section-title">Rekommendationer</div>

        @if (isLoadingRecommendations)
        {
            <div class="loading-box">
                <p>Analyserar dina resultat<span class="loading-dots"></span></p>
            </div>
        }
        else if (recommendationError != null)
        {
            <div class="error-message">@recommendationError</div>
        }
        else if (recommendations != null)
        {
            @if (!string.IsNullOrEmpty(recommendations.Summary))
            {
                <div class="summary-box">
                    <p>@recommendations.Summary</p>
                </div>
            }

            @if (recommendations.Recommendations.Any())
            {
                <div class="recommendations">
                    @foreach (var rec in recommendations.Recommendations)
                    {
                        var score = GetScoreForTopic(rec.Topic);
                        var cardClass = score < 50 ? "weak" : score < 75 ? "medium" : "strong";
                        var scoreLabel = score < 50 ? "Svagt" : score < 75 ? "Okej" : "Bra";

                        <div class="rec-card @cardClass">
                            <div class="rec-header">
                                <div class="rec-topic">@rec.Topic</div>
                                <div class="rec-badge @cardClass">@scoreLabel</div>
                            </div>
                            <div class="rec-reason">@rec.Reason</div>

                            @if (rec.RecommendedResources.Any())
                            {
                                <div class="rec-resources">
                                    @foreach (var resource in rec.RecommendedResources)
                                    {
                                        <a href="@resource.Url" target="_blank" class="resource-link">
                                            @resource.Title
                                        </a>
                                    }
                                </div>
                            }

                            @if (rec.KeyConceptsToFocus.Any())
                            {
                                <div class="rec-concepts">
                                    @foreach (var concept in rec.KeyConceptsToFocus)
                                    {
                                        <span class="concept-tag">@concept</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="muted-text">Inga rekommendationer just nu. Gör fler quiz för att få personliga råd!</p>
            }
        }

        <!-- ═══ ZON 3: CHATT ═══ -->
        <div class="section-title">Chatta med din coach</div>

        <div class="chat-wrapper">
            <div class="chat-messages">

                <div class="msg ai">
                    <div class="msg-bubble">
                        Hej! Jag är din AI Coach. Jag kan svara på frågor om cybersäkerhet och hjälpa dig förstå dina quiz-resultat. Vad undrar du?
                    </div>
                </div>

                @foreach (var msg in chatMessages)
                {
                    <div class="msg @(msg.IsUser ? "user" : "ai")">
                        <div class="msg-bubble">@msg.Text</div>
                    </div>
                }

                @if (isLoadingChat)
                {
                    <div class="msg ai">
                        <div class="typing-indicator">
                            <div class="typing-dot"></div>
                            <div class="typing-dot"></div>
                            <div class="typing-dot"></div>
                        </div>
                    </div>
                }
            </div>

            @if (!chatMessages.Any())
            {
                <div class="suggestions">
                    <div class="suggestion-chip" @onclick='() => SetSuggestion("Vad är phishing och hur känner man igen det?")'>Vad är phishing?</div>
                    <div class="suggestion-chip" @onclick='() => SetSuggestion("Förklara SQL injection på ett enkelt sätt")'>Förklara SQL injection</div>
                    <div class="suggestion-chip" @onclick='() => SetSuggestion("Ge mig ett studietips för idag")'>Ge mig ett studietips</div>
                </div>
            }

            <div class="chat-input-area">
                <input type="text"
                       class="chat-input"
                       placeholder="Skriv din fråga här..."
                       @bind="currentMessage"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
                <button class="btn-send"
                        @onclick="SendMessage"
                        disabled="@(isLoadingChat || string.IsNullOrWhiteSpace(currentMessage))">
                    Skicka
                </button>
            </div>
        </div>

        <button class="btn-back" @onclick="GoBack">Tillbaka till kategorier</button>

    </div>
</div>

<style>
    .coach-container {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        background: #f0f2f5;
        padding: 2rem 1rem;
    }

    .coach-card {
        background: white;
        border-radius: 16px;
        padding: 3rem 2.5rem;
        text-align: center;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        max-width: 680px;
        width: 100%;
    }

    .shield {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .coach-card h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 0.75rem 0;
    }

    .coach-card > p {
        color: #666;
        font-size: 1rem;
        margin-bottom: 2rem;
    }

    /* STATS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-bottom: 2rem;
        text-align: left;
    }

    .stat-card {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
    }

    .stat-label {
        font-size: 0.75rem;
        color: #888;
        margin-bottom: 0.4rem;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a2e;
    }

        .stat-value.green {
            color: #16a34a;
        }

        .stat-value.orange {
            color: #d97706;
            font-size: 0.95rem;
            padding-top: 0.3rem;
        }

    /* SECTION TITLE */
    .section-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #aaa;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #e0e0e0;
        text-align: left;
    }

    /* LOADING */
    .loading-box {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.5rem;
        text-align: center;
        color: #888;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    /* Animerade prickar */
    .loading-dots::after {
        content: '';
        display: inline-block;
        width: 1.5em;  /* Fast bredd för att förhindra text-hopp */
        text-align: left;
        animation: dots 1.5s steps(4, end) infinite;
    }

    @@keyframes dots {
        0%, 20% { content: '.'; }
        40% { content: '..'; }
        60% { content: '...'; }
        80%, 100% { content: ''; }
    }

    /* ERROR */
    .error-message {
        background: #fee2e2;
        color: #dc2626;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        text-align: left;
    }

    /* SUMMARY */
    .summary-box {
        border: 2px solid #e0e0e0;
        border-left: 4px solid #4f46e5;
        border-radius: 0 8px 8px 0;
        padding: 1rem 1.2rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        color: #444;
        line-height: 1.6;
        text-align: left;
    }

        .summary-box p {
            margin: 0;
        }

    /* REKOMMENDATIONER */
    .recommendations {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 2rem;
    }

    .rec-card {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.2rem;
        border-left: 4px solid #e0e0e0;
        text-align: left;
    }

        .rec-card.weak {
            border-left-color: #ef4444;
        }

        .rec-card.medium {
            border-left-color: #f59e0b;
        }

        .rec-card.strong {
            border-left-color: #16a34a;
        }

    .rec-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .rec-topic {
        font-weight: 600;
        font-size: 0.95rem;
        color: #1a1a2e;
    }

    .rec-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
    }

        .rec-badge.weak {
            background: #fee2e2;
            color: #dc2626;
        }

        .rec-badge.medium {
            background: #fef3c7;
            color: #d97706;
        }

        .rec-badge.strong {
            background: #dcfce7;
            color: #16a34a;
        }

    .rec-reason {
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 0.75rem;
        line-height: 1.5;
    }

    .rec-resources {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .resource-link {
        display: inline-block;
        padding: 0.3rem 0.75rem;
        border: 2px solid #e0e0e0;
        border-radius: 6px;
        color: #4f46e5;
        font-size: 0.8rem;
        text-decoration: none;
        transition: background 0.2s, border-color 0.2s;
    }

        .resource-link:hover {
            background: #f0f2f5;
            border-color: #4f46e5;
        }

    .rec-concepts {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.5rem;
    }

    .concept-tag {
        padding: 0.2rem 0.6rem;
        background: #f0f2f5;
        border-radius: 4px;
        font-size: 0.75rem;
        color: #666;
    }

    .muted-text {
        color: #aaa;
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }

    /* CHATT */
    .chat-wrapper {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        text-align: left;
    }

    .chat-messages {
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-height: 180px;
        max-height: 360px;
        overflow-y: auto;
        background: #f0f2f5;
    }

    .msg {
        display: flex;
        max-width: 80%;
    }

        .msg.user {
            align-self: flex-end;
        }

    .msg-bubble {
        padding: 0.7rem 1rem;
        border-radius: 12px;
        font-size: 0.875rem;
        line-height: 1.55;
    }

    .msg.ai .msg-bubble {
        background: white;
        color: #1a1a2e;
        border: 2px solid #e0e0e0;
        border-bottom-left-radius: 4px;
    }

    .msg.user .msg-bubble {
        background: #4f46e5;
        color: white;
        border-bottom-right-radius: 4px;
    }

    /* TYPING */
    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 0.7rem 1rem;
        background: white;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        border-bottom-left-radius: 4px;
        width: fit-content;
        align-items: center;
    }

    .typing-dot {
        width: 7px;
        height: 7px;
        background: #ccc;
        border-radius: 50%;
        animation: bounce 1.2s ease-in-out infinite;
    }

        .typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    @@keyframes bounce {
        0%, 80%, 100% {
            transform: translateY(0);
        }

        40% {
            transform: translateY(-6px);
        }
    }

    /* SUGGESTIONS */
    .suggestions {
        padding: 0.75rem 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        background: white;
        border-top: 1px solid #e0e0e0;
    }

    .suggestion-chip {
        padding: 0.35rem 0.85rem;
        border: 2px solid #e0e0e0;
        border-radius: 20px;
        font-size: 0.78rem;
        color: #666;
        cursor: pointer;
        background: #f0f2f5;
        transition: border-color 0.2s, color 0.2s;
    }

        .suggestion-chip:hover {
            border-color: #4f46e5;
            color: #4f46e5;
        }

    /* INPUT */
    .chat-input-area {
        padding: 0.75rem 1rem;
        border-top: 1px solid #e0e0e0;
        display: flex;
        gap: 0.6rem;
        background: white;
    }

    .chat-input {
        flex: 1;
        padding: 0.75rem 1rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.2s;
    }

        .chat-input:focus {
            border-color: #4f46e5;
        }

    .btn-send {
        padding: 0.75rem 1.2rem;
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 600;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

        .btn-send:hover:not(:disabled) {
            opacity: 0.85;
        }

        .btn-send:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

    /* BACK BTN — samma stil som btn-register på Home */
    .btn-back {
        display: block;
        width: 100%;
        padding: 0.85rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        border: 2px solid #e0e0e0;
        cursor: pointer;
        background: #f0f2f5;
        color: #4f46e5;
        transition: opacity 0.2s;
        margin-top: 0.5rem;
    }

        .btn-back:hover {
            opacity: 0.85;
        }
</style>

@code {
    [SupplyParameterFromQuery(Name = "subCategoryId")]
    public int? SubCategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "subCategoryName")]
    public string? SubCategoryName { get; set; }

    private AIRecommendationResponseDto? recommendations;
    private bool isLoadingRecommendations = true;
    private string? recommendationError;

    private List<ChatMessage> chatMessages = new();
    private string currentMessage = "";
    private bool isLoadingChat = false;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        userId = AuthService.UserId;

        if (userId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadRecommendations();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Körs varje gång SubCategoryId eller SubCategoryName ändras i URL:en
        // Detta säkerställer att nya recommendations laddas vid navigering
        if (userId != null)
        {
            await LoadRecommendations();
        }
    }

    private async Task LoadRecommendations()
    {
        isLoadingRecommendations = true;
        recommendationError = null;
        recommendations = null;  //Rensa gamla recommendations

        try
        {
            var url = SubCategoryId.HasValue
                ? $"api/ai/recommendations?subCategoryId={SubCategoryId}&testUserId={userId}"
                : $"api/ai/recommendations?testUserId={userId}";

            recommendations = await Http.GetFromJsonAsync<AIRecommendationResponseDto>(url);
        }
        catch (Exception ex)
        {
            recommendationError = $"Kunde inte hämta AI-analys. Kontrollera att Ollama körs. ({ex.Message})";
        }
        finally
        {
            isLoadingRecommendations = false;
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage) || isLoadingChat)
            return;

        var userText = currentMessage.Trim();
        currentMessage = "";

        chatMessages.Add(new ChatMessage { Text = userText, IsUser = true });
        isLoadingChat = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/ai/chat", new AIChatRequestDto
            {
                UserId = userId!,
                Message = userText
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponse>();
                chatMessages.Add(new ChatMessage
                {
                    Text = result?.Message ?? "Inget svar.",
                    IsUser = false
                });
            }
            else
            {
                chatMessages.Add(new ChatMessage
                {
                    Text = "Kunde inte få svar från AI. Kontrollera att Ollama körs.",
                    IsUser = false
                });
            }
        }
        catch
        {
            chatMessages.Add(new ChatMessage
            {
                Text = "Något gick fel. Kontrollera att Ollama körs.",
                IsUser = false
            });
        }
        finally
        {
            isLoadingChat = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }

    private void SetSuggestion(string text)
    {
        currentMessage = text;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/categories");
    }

    private double GetScoreForTopic(string topic)
    {
        if (recommendations == null) return 50;
        if (recommendations.WeakestCategory == topic) return 30;
        if (recommendations.StrongestCategory == topic) return 90;
        return 60;
    }

    private class ChatMessage
    {
        public string Text { get; set; } = string.Empty;
        public bool IsUser { get; set; }
    }

    private class ChatResponse
    {
        public string? Message { get; set; }
    }
}
