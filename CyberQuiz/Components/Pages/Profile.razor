@page "/profile"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using CyberQuiz.Shared.DTOs

<PageTitle>Min Profil</PageTitle>

<div class="profile-container">
    <h2>Min Progression</h2>

    @if (categories == null)
    {
        <p>Laddar progression...</p>
    }
    else
    {
        @foreach (var category in categories)
        {
            <h3 class="category-heading">@category.Name</h3>
            @foreach (var sc in category.SubCategories)
            {
                var cssClass = GetStatusClass(sc.Id, sc.IsUnlocked);
                var label = GetStatusLabel(sc.Id, sc.IsUnlocked);
                <div class="progression-card @cssClass">
                    <span class="subcategory-name">@sc.Name</span>
                    <span class="status-label">@label</span>
                </div>
            }
        }
    }

    <div class="manage-links">
        <h3>Kontoinställningar</h3>
        <a href="/Email" class="manage-btn">Ändra e-post</a>
        <a href="/ChangePassword" class="manage-btn">Ändra lösenord</a>
    </div>

    <button class="back-btn" @onclick="GoBack">← Tillbaka</button>
</div>

<style>
    .profile-container {
        max-width: 500px;
        margin: 2rem auto;
        padding: 1rem;
    }

        .profile-container h2 {
            margin-bottom: 1.5rem;
        }

    .category-heading {
        font-size: 1rem;
        font-weight: 600;
        color: #444;
        margin: 1.5rem 0 0.5rem 0;
    }

    .progression-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 2px dashed #ccc;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
    }

        .progression-card.passed {
            border-color: #16a34a;
            background: #dcfce7;
        }

        .progression-card.not-passed {
            border-color: #dc2626;
            background: #fee2e2;
        }

        .progression-card.locked {
            border-color: #ccc;
            background: #f5f5f5;
            color: #999;
        }

    .subcategory-name {
        font-size: 0.95rem;
    }

    .status-label {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .manage-links {
        margin-top: 2rem;
        padding: 1.5rem;
        border: 2px dashed #ccc;
        border-radius: 8px;
        background: white;
    }

        .manage-links h3 {
            margin-bottom: 1rem;
            font-size: 1rem;
            color: #444;
        }

    .manage-btn {
        display: block;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        border: 2px solid #7c3aed;
        border-radius: 6px;
        color: #7c3aed;
        text-decoration: none;
        font-size: 0.95rem;
    }

        .manage-btn:hover {
            background: #f3f0ff;
        }

    .back-btn {
        margin-top: 1rem;
        padding: 0.75rem 1.5rem;
        background: #7c3aed;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1rem;
    }

        .back-btn:hover {
            background: #6d28d9;
        }
</style>

@code {
    private List<CategoryDto>? categories = null;
    // SubCategoryId → IsPassed, bara för subkategorier användaren besökt
    private Dictionary<int, bool> progressionMap = new();

    protected override async Task OnInitializedAsync()
    {
        var userId = AuthService.UserId;

        if (userId == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        // Kör båda anropen parallellt
        var progressionTask = Http.GetFromJsonAsync<List<ProgressionDto>>(
            $"api/user/progression?userId={userId}");
        var categoriesTask = Http.GetFromJsonAsync<List<CategoryDto>>(
            $"api/categories?userId={userId}");

        await Task.WhenAll(progressionTask, categoriesTask);

        categories = categoriesTask.Result;

        // Bygg uppslagstabell: subCategoryId → IsPassed
        progressionMap = (progressionTask.Result ?? [])
            .ToDictionary(p => p.SubCategoryId, p => p.IsPassed);
    }

    private string GetStatusClass(int subCategoryId, bool isUnlocked)
    {
        if (!isUnlocked) return "locked";
        if (progressionMap.TryGetValue(subCategoryId, out var isPassed) && isPassed) return "passed";
        return "not-passed";
    }

    private string GetStatusLabel(int subCategoryId, bool isUnlocked)
    {
        if (!isUnlocked) return "🔒 Låst";
        if (progressionMap.TryGetValue(subCategoryId, out var isPassed) && isPassed) return "Klarad";
        return "Ej klarad";
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/categories");
    }
}
