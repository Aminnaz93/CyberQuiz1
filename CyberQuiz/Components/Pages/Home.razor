@page "/"
@rendermode InteractiveServer

<PageTitle>CyberQuiz</PageTitle>

<div class="home-container">
    <div class="home-card">
        <div class="shield">🛡️</div>
        <h1>CyberQuiz</h1>
        <p>Testa dina kunskaper inom cybersäkerhet!</p>

        <div class="btn-group">
            <a href="/login" class="btn-login">Logga in</a>
            <a href="/register" class="btn-register">Registrera dig</a>
        </div>
    </div>
</div>

<style>
    .home-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f0f2f5;
    }

    .home-card {
        background: white;
        border-radius: 16px;
        padding: 3rem 2.5rem;
        text-align: center;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        max-width: 400px;
        width: 100%;
    }

    .shield {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .home-card h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 0.75rem 0;
    }

    .home-card p {
        color: #666;
        font-size: 1rem;
        margin-bottom: 2rem;
    }

    .btn-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-login, .btn-register {
        display: block;
        padding: 0.85rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .btn-login {
        background: #4f46e5;
        color: white;
    }

    .btn-register {
        background: #f0f2f5;
        color: #4f46e5;
        border: 2px solid #e0e0e0;
    }

        .btn-login:hover, .btn-register:hover {
            opacity: 0.85;
        }
</style>
