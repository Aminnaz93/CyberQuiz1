@page "/changepassword"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using CyberQuiz.Shared.DTOs

<PageTitle>Ändra lösenord</PageTitle>

<div class="row">
    <div class="col-md-4">

        <h2>Ändra lösenord</h2>

        @if (errorMessage != null)
        {
            <p class="text-danger">@errorMessage</p>
        }

        @if (successMessage != null)
        {
            <p class="text-success">@successMessage</p>
        }

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="Nuvarande lösenord"
                   @bind="currentPassword" />
            <label>Nuvarande lösenord</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="Nytt lösenord"
                   @bind="newPassword" />
            <label>Nytt lösenord</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="Bekräfta nytt lösenord"
                   @bind="confirmNewPassword" />
            <label>Bekräfta nytt lösenord</label>
        </div>

        <button class="w-100 btn btn-lg btn-primary" @onclick="HandleChangePassword">Spara</button>

        <hr />
        <p><a href="/profile">← Tillbaka till profil</a></p>

    </div>
</div>

@code {
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmNewPassword = "";
    private string? errorMessage;
    private string? successMessage;

    protected override void OnInitialized()
    {
        // Om användaren inte är inloggad — gå till login
        if (!AuthService.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task HandleChangePassword()
    {
        errorMessage = null;
        successMessage = null;

        // Kolla att lösenorden matchar innan vi skickar till API
        if (newPassword != confirmNewPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        var dto = new ChangePasswordDto
        {
            CurrentPassword = currentPassword,
            NewPassword = newPassword,
            ConfirmNewPassword = confirmNewPassword
        };

        // Skickar till API
        var response = await Http.PutAsJsonAsync("api/auth/password", dto);

        if (response.IsSuccessStatusCode)
        {
            successMessage = "Lösenord har bytts!";
            currentPassword = "";
            newPassword = "";
            confirmNewPassword = "";
        }
        else
        {
            errorMessage = "Något gick fel. Kontrollera att nuvarande lösenord är rätt.";
        }
    }
}
