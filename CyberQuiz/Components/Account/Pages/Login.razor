@page "/Account/login"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using System.ComponentModel.DataAnnotations

<PageTitle>Logga in</PageTitle>

<div class="row">
    <div class="col-md-4">

        <h2>Logga in</h2>

        @if (errorMessage != null)
        {
            <p class="text-danger">@errorMessage</p>
        }

        <div class="form-floating mb-3">
            <input type="email" class="form-control" placeholder="name@example.com"
                   @bind="email" />
            <label>Email</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="password"
                   @bind="password" />
            <label>Lösenord</label>
        </div>

        <button class="w-100 btn btn-lg btn-primary" @onclick="LoginUser">Logga in</button>

        <hr />
        <p>Inget konto? <a href="/register">Registrera dig här</a></p>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;

    private async Task LoginUser()
    {
        errorMessage = null;

        var success = await AuthService.LoginAsync(email, password);

        if (success)
        {
            NavigationManager.NavigateTo("/categories");
        }
        else
        {
            errorMessage = "Fel e-post eller lösenord.";
        }
    }
}