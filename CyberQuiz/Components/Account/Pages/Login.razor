@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.AuthService AuthService
@using System.ComponentModel.DataAnnotations

<PageTitle>Logga in</PageTitle>

<div class="row">
    <div class="col-md-4">

        <h2>Logga in</h2>

        @if (errorMessage != null)
        {
            <p class="text-danger">@errorMessage</p>
        }

        <div class="form-floating mb-3">
            <input type="email" class="form-control" placeholder="name@example.com"
                   @bind="email" @bind:event="oninput" />
            <label>Email</label>
        </div>

        <div class="form-floating mb-3">
            <input type="password" class="form-control" placeholder="password"
                   @bind="password" @bind:event="oninput" />
            <label>Lösenord</label>
        </div>

        <button class="w-100 btn btn-lg btn-primary" @onclick="LoginUser" disabled="@(!isReady)">Logga in</button>

        <hr />
        <p>Inget konto? <a href="/register">Registrera dig här</a></p>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool isReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isReady = true;
            StateHasChanged();
        }
    }

    private async Task LoginUser()
    {
        errorMessage = null;

        bool success;
        try
        {
            success = await AuthService.LoginAsync(email, password);
        }
        catch (Exception ex)
        {
            errorMessage = $"Fel: {ex.Message}";
            return;
        }

        if (success)
        {
            NavigationManager.NavigateTo("/categories", forceLoad: true);
        }
        else
        {
            errorMessage = "Fel e-post eller lösenord.";
        }
    }
}